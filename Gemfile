# Only needed if you install Ruby to preview the site locally.
# GitHub Pages does NOT use this file to build — it uses its own
# pinned github-pages environment. This just mirrors it locally.
#
#   gem install bundler
#   bundle install
#   bundle exec jekyll serve   # → http://localhost:4000

source "https://rubygems.org"

gem "github-pages", group: :jekyll_plugins

# Required on Ruby 3.0+ (WEBrick was removed from the standard library)
gem "webrick", "~> 1.8"
